{
  "expo": {
    "name": "Aria Senior",
    "slug": "aria-senior2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forgedis.ariasenior",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Aria a besoin du microphone pour vous ecouter.",
        "NSLocationWhenInUseUsageDescription": "Aria utilise votre position pour la meteo locale."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.forgedis.ariasenior",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d956056b-c20d-4f28-8f84-82c4efa607a5"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0F"
        }
      ],
      [
        "expo-network-security-config",
        {
          "networkSecurityConfig": "./assets/configs/network_security_config.xml",
          "enable": true
        }
      ],
      "expo-audio",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Aria a besoin du micro pour vous ecouter.",
          "speechRecognitionPermission": "Aria a besoin de la reconnaissance vocale pour comprendre vos demandes.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ]
  }
}